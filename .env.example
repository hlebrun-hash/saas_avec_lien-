# ─────────────────────────────────────────────────────────────
# InfluenceMatch — environment variables
# Copy to .env.local for development.
# ─────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME="InfluenceMatch"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Set to "true" to disable Clerk and use a stubbed dev user (mock-mode).
DEV_AUTH_BYPASS="true"

# Database (Postgres). Use docker-compose locally or Neon/Supabase in prod.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/influencematch?schema=public"

# Anthropic Claude — required for niche inference. If absent, lib falls back to a deterministic stub.
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# Clerk auth (leave empty to use DEV_AUTH_BYPASS)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"

# Upstash Redis (for rate limiting). If absent, an in-memory limiter is used.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Inngest (background jobs). Optional — analyze runs synchronously when absent.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# Stripe (test mode keys). Leave empty to disable billing UI.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_PRICE_PRO=""
STRIPE_PRICE_AGENCY=""

# PostHog analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# Influencer data provider. "mock" ships with the seed dataset. Real options: "modash" | "phyllo" (TODO: implement adapter).
INFLUENCER_PROVIDER="mock"
MODASH_API_KEY=""
